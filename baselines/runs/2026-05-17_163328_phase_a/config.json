{
  "name": "phase_a",
  "seed": 42,
  "placement": "all",
  "split": "participant_disjoint",
  "test_size": 0.2,
  "val_size": 0.1,
  "model": "hybrid",
  "width_multiplier": 1.5,
  "depth": 2,
  "dropout": 0.25,
  "n_classes": 3,
  "input_len": 512,
  "n_features": 18,
  "loss": "focal",
  "focal_gamma": 2.0,
  "class_weight": "inverse",
  "epochs": 150,
  "batch_size": 64,
  "learning_rate": 0.003,
  "schedule": "cosine_warmup",
  "warmup_frac": 0.05,
  "early_stopping_patience": 25,
  "augment_shift": true,
  "shift_max": 40,
  "augment_scale": true,
  "scale_min": 0.8,
  "scale_max": 1.2,
  "augment_noise": true,
  "noise_std": 0.05,
  "augment_time_warp": true,
  "warp_strength": 0.1,
  "augment_mixup": false,
  "mixup_alpha": 0.2,
  "out_dir": "runs",
  "save_model": true,
  "save_plots": true,
  "verbose": 2
}